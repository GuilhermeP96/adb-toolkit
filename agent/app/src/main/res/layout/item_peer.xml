<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:checkedIcon="@android:drawable/checkbox_on_background"
    app:checkable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Device/notebook icon -->
        <ImageView
            android:id="@+id/ivPeerIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_transfer"
            android:contentDescription="peer"
            app:tint="?attr/colorPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvPeerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Galaxy S24 Ultra" />

            <TextView
                android:id="@+id/tvPeerAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="?android:textColorSecondary"
                tools:text="192.168.1.42:15555" />

            <TextView
                android:id="@+id/tvPeerRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                tools:text="Origem • Android" />

        </LinearLayout>

        <!-- Connection status -->
        <View
            android:id="@+id/viewPeerStatus"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@android:color/holo_green_dark" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
